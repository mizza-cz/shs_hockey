<section class="pt-xl-16 pt-12 mb-xxl-30 mb-lg-20 mb-15">
  <div class="container">
    <h1 class="h1 text-center mb-lg-8 mb-6">O nás</h1>
    <div class="row g-8 mb-lg-16 mb-10 align-items-center">
      <div class="col-lg-5">
        <img
