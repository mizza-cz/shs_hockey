<section class="auth-section pt-8 mb-xxl-30 mb-lg-20 mb-15">
  <div class="container">
    <div class="mb-6 text-center">
      <h1 class="h2 mb-3">Přihlášení</h1>
      <p class="text-md text-gray-600">Vítejte zpět, prosím přihlaste se.</p>
    </div>
    <ul class="nav auth-tabs" id="authTabs" role="tablist">
      <li class="auth-tabs__item" role="presentation">
        <button
          class="auth-tabs__link active"
          id="register-tab"
          data-bs-toggle="tab"
          data-bs-target="#register-pane"
          type="button"
          role="tab"
          aria-controls="register-pane"
          aria-selected="true"
        >
          Registrace
        </button>
      </li>
      <li class="auth-tabs__item" role="presentation">
        <button
          class="auth-tabs__link"
          id="invite-tab"
          data-bs-toggle="tab"
          data-bs-target="#invite-pane"
          type="button"
          role="tab"
          aria-controls="invite-pane"
          aria-selected="false"
        >
          Přihlášení
        </button>
      </li>
    </ul>

    <div class="tab-content auth-content" id="authTabsContent">
      <div
        class="tab-pane fade show active"
        id="register-pane"
        role="tabpanel"
        aria-labelledby="register-tab"
        tabindex="0"
      >
        <form class="auth-form" action="/register" method="POST">
          <div class="mb-5">
            <label for="email" class="form-label">
              E-mail <span class="required">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              class="form-control"
              placeholder="Zadejte e-mail"
              required
            />
          </div>

          <div class="mb-5">
            <label for="firstName" class="form-label">
              Jméno <span class="required">*</span>
            </label>
            <input
              id="firstName"
              name="firstName"
              type="text"
              class="form-control"
              placeholder="Zadejte jméno"
              required
            />
          </div>

          <div class="mb-5">
            <label for="lastName" class="form-label">
              Příjmení <span class="required">*</span>
            </label>
            <input
              id="lastName"
              name="lastName"
              type="text"
              class="form-control"
              placeholder="Zadejte příjmení"
              required
            />
          </div>

          <div class="row gx-3 gy-5 mb-5">
            <div class="col-sm-6">
              <label for="club" class="form-label">
                Klub <span class="required">*</span>
              </label>
              <input
                id="club"
                name="club"
                type="text"
                class="form-control"
                placeholder="Vyplňte"
                required
              />
            </div>

            <div class="col-sm-6">
              <label for="position" class="form-label">
                Pozice <span class="required">*</span>
              </label>
              <select id="position" name="position" class="js-select" required>
                <option value="forward">Útočník</option>
                <option value="goalkeeper">Brankář</option>
                <option value="defender">Obránce</option>
                <option value="midfielder">Záložník</option>
              </select>
            </div>
          </div>

          <div class="mb-5">
            <label for="password" class="form-label">
              Heslo <span class="required">*</span>
            </label>
            <input
              id="password"
              name="password"
              type="password"
              class="form-control"
              placeholder="••••••••"
              required
            />
          </div>

          <div class="mb-5">
            <label for="passwordConfirm" class="form-label">
              Heslo znovu pro kontrolu <span class="required">*</span>
            </label>
            <input
              id="passwordConfirm"
              name="passwordConfirm"
              type="password"
              class="form-control"
              placeholder="••••••••"
              required
            />
          </div>

          <button type="submit" class="button-primary button-lg w-100">
            Vytvořit účet
          </button>

          <div class="mt-lg-8 mt-5 text-gray-600 text-sm text-center">
            Již máte účet?
            <a href="#" class="text-brand-700 fw-bold hover-outline">
              Přihlaste se
            </a>
          </div>
        </form>
      </div>

      <div
        class="tab-pane fade"
        id="invite-pane"
        role="tabpanel"
        aria-labelledby="invite-tab"
        tabindex="0"
      >
        <form class="auth-form" action="/login" method="POST">
          <div class="mb-5">
            <label for="loginEmail" class="form-label">E-mail</label>
            <input
              id="loginEmail"
              name="email"
              type="email"
              class="form-control"
              placeholder="Zadejte e-mail"
              autocomplete="email"
              required
            />
          </div>

          <div class="mb-lg-6 mb-5">
            <label for="loginPassword" class="form-label">Heslo</label>
            <input
              id="loginPassword"
              name="password"
              type="password"
              class="form-control"
              placeholder="••••••••"
              autocomplete="current-password"
              required
            />
          </div>

          <div
            class="d-flex justify-content-between align-items-center mb-lg-6 mb-5 checkbox-row gap-3 flex-wrap"
          >
            <div class="form-check">
              <input
                class="form-check-input"
                type="checkbox"
                id="rememberMe"
                name="remember"
              />
              <label class="fw-medium text-sm text-gray-700" for="rememberMe">
                Zapamatovat na 30 dnů
              </label>
            </div>

            <a href="#" class="text-brand-700 fw-bold text-sm hover-outline">
              Zapomenuté heslo?
            </a>
          </div>

          <button type="submit" class="btn btn-danger btn-auth w-100">
            Přihlásit se
          </button>

          <div class="mt-lg-8 mt-5 text-gray-600 text-sm text-center">
            Ještě nemáte účet?
            <a href="#" class="text-brand-700 fw-bold hover-outline">
              Registrujte se
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
